# Kernel config fragment for EVL/Dovetail smoke tests on QEMU riscv64 virt.
#
# This fragment is intentionally generic: it targets the standard QEMU `virt`
# machine so we can validate generic RISC-V + IRQ pipeline + Dovetail + EVL
# bring-up without pulling in SpacemiT K1 board support.

CONFIG_SOC_SPACEMIT=n
CONFIG_ARCH_SPACEMIT=n

CONFIG_CMDLINE_BOOL=y
CONFIG_CMDLINE="console=ttyS0 earlycon=sbi"
CONFIG_CMDLINE_EXTEND=y

CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y

CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_ZSTD=y

CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_RPMSG_VIRTIO=n

CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCI_HOST_GENERIC=y

CONFIG_EXT4_FS=y
CONFIG_FUSE_FS=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y

CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_NET=y
CONFIG_INET=y

CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_GOLDFISH=y

CONFIG_OCP2138=n
CONFIG_SPACEMIT_TCM=n
CONFIG_SPACEMIT_V2D=n

CONFIG_EFI=n
