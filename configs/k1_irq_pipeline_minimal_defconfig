# =============================================================================
# k1_irq_pipeline_minimal_defconfig
# Smallest practical Jupiter bring-up slice for IRQ pipeline debugging:
#   - IRQ pipeline enabled
#   - no Dovetail
#   - no EVL
#   - no SMP / no IPI fan-out
#   - no idle / no broadcast tick
#   - no PM / suspend path
#   - no FPU / no Vector state
#
# If this variant still hangs, the blocker is likely in the single-core local
# IRQ/timer/trap path itself rather than in SMP, idle, EVL, or FPU handling.
# =============================================================================

CONFIG_LOCALVERSION=""
# CONFIG_LOCALVERSION_AUTO is not set

CONFIG_IRQ_PIPELINE=y
# CONFIG_DOVETAIL is not set
# CONFIG_EVL is not set

CONFIG_HIGH_RES_TIMERS=y
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_PREEMPT=y

# Remove platform PM / suspend interactions from the first minimal check.
# CONFIG_PM is not set
# CONFIG_SUSPEND is not set
# CONFIG_PM_SLEEP is not set
# CONFIG_SPACEMIT_LID_CONTROL is not set
# CONFIG_SPACEMIT_WATCHDOG is not set

# Collapse to one CPU so no IPI or cross-CPU pipeline path can trigger.
# CONFIG_SMP is not set
# CONFIG_HOTPLUG_CPU is not set

# Remove idle and broadcast-tick interactions.
# CONFIG_CPU_IDLE is not set
# CONFIG_NO_HZ_IDLE is not set
# CONFIG_GENERIC_CLOCKEVENTS_BROADCAST is not set

# Keep the architecture state model as small as possible.
# CONFIG_FPU is not set
# CONFIG_RISCV_ISA_V is not set

# Disable known-broken vendor Wi-Fi modules for current toolchains.
# CONFIG_BCMDHD is not set
# CONFIG_RTL8852BS is not set
