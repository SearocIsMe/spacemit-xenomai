diff --git a/arch/riscv/include/dovetail/thread_info.h b/arch/riscv/include/dovetail/thread_info.h
new file mode 100644
index 000000000..416c11ca7
--- /dev/null
+++ b/arch/riscv/include/dovetail/thread_info.h
@@ -0,0 +1,15 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * RISC-V Dovetail per-thread OOB state.
+ *
+ * The actual oob_thread_state struct is defined by the EVL co-kernel
+ * in include/asm-generic/evl/thread_info.h (struct evl_thread pointer,
+ * subscriber pointer, preempt_count). When CONFIG_EVL is not set, it
+ * falls back to an empty struct.
+ */
+#ifndef _RISCV_DOVETAIL_THREAD_INFO_H
+#define _RISCV_DOVETAIL_THREAD_INFO_H
+
+#include <asm-generic/evl/thread_info.h>
+
+#endif /* _RISCV_DOVETAIL_THREAD_INFO_H */
diff --git a/arch/riscv/kernel/traps.c b/arch/riscv/kernel/traps.c
index 865f191ab..ce74bf9d0 100644
--- a/arch/riscv/kernel/traps.c
+++ b/arch/riscv/kernel/traps.c
@@ -20,6 +20,7 @@
 #include <linux/irq.h>
 #include <linux/kexec.h>
 #include <linux/entry-common.h>
+#include <linux/irq_pipeline.h>
 
 #include <asm/asm-prototypes.h>
 #include <asm/bug.h>
@@ -364,6 +365,17 @@ static void noinstr handle_riscv_irq(struct pt_regs *regs)
 {
 	struct pt_regs *old_regs;
 
+#ifdef CONFIG_IRQ_PIPELINE
+	/*
+	 * When the Dovetail IRQ pipeline is active, route the interrupt
+	 * through handle_irq_pipelined() which handles set_irq_regs()
+	 * internally and delivers pending in-band IRQs on exit.
+	 */
+	if (irq_pipeline_active()) {
+		handle_irq_pipelined(regs);
+		return;
+	}
+#endif
 	irq_enter_rcu();
 	old_regs = set_irq_regs(regs);
 	handle_arch_irq(regs);
