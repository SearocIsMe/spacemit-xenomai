diff --git a/arch/riscv/include/uapi/asm/evl/fptest.h b/arch/riscv/include/uapi/asm/evl/fptest.h
new file mode 100644
index 000000000..25e3d36da
--- /dev/null
+++ b/arch/riscv/include/uapi/asm/evl/fptest.h
@@ -0,0 +1,85 @@
+/* SPDX-License-Identifier: GPL-2.0 WITH Linux-syscall-note */
+/*
+ * RISC-V EVL FPU test support.
+ * RISC-V uses the F/D extensions for floating point.
+ */
+#ifndef _EVL_RISCV_ASM_UAPI_FPTEST_H
+#define _EVL_RISCV_ASM_UAPI_FPTEST_H
+
+#include <linux/types.h>
+
+#define evl_riscv_fp  0x1
+
+/*
+ * RISC-V FP registers: f0-f31 (64-bit each with D extension).
+ * Load all 32 FP registers with the given value.
+ */
+#define evl_set_fpregs(__features, __val)				\
+	do {								\
+		if (__features & evl_riscv_fp) {			\
+			double __v = (double)(__val);			\
+			__asm__ __volatile__(				\
+				"fmv.d.x f0, %0\n"			\
+				"fmv.d.x f1, %0\n"			\
+				"fmv.d.x f2, %0\n"			\
+				"fmv.d.x f3, %0\n"			\
+				"fmv.d.x f4, %0\n"			\
+				"fmv.d.x f5, %0\n"			\
+				"fmv.d.x f6, %0\n"			\
+				"fmv.d.x f7, %0\n"			\
+				"fmv.d.x f8, %0\n"			\
+				"fmv.d.x f9, %0\n"			\
+				"fmv.d.x f10, %0\n"			\
+				"fmv.d.x f11, %0\n"			\
+				"fmv.d.x f12, %0\n"			\
+				"fmv.d.x f13, %0\n"			\
+				"fmv.d.x f14, %0\n"			\
+				"fmv.d.x f15, %0\n"			\
+				"fmv.d.x f16, %0\n"			\
+				"fmv.d.x f17, %0\n"			\
+				"fmv.d.x f18, %0\n"			\
+				"fmv.d.x f19, %0\n"			\
+				"fmv.d.x f20, %0\n"			\
+				"fmv.d.x f21, %0\n"			\
+				"fmv.d.x f22, %0\n"			\
+				"fmv.d.x f23, %0\n"			\
+				"fmv.d.x f24, %0\n"			\
+				"fmv.d.x f25, %0\n"			\
+				"fmv.d.x f26, %0\n"			\
+				"fmv.d.x f27, %0\n"			\
+				"fmv.d.x f28, %0\n"			\
+				"fmv.d.x f29, %0\n"			\
+				"fmv.d.x f30, %0\n"			\
+				"fmv.d.x f31, %0\n"			\
+				: /* no outputs */			\
+				: "r"((unsigned long)(__val))		\
+				: "f0","f1","f2","f3","f4","f5",	\
+				  "f6","f7","f8","f9","f10","f11",	\
+				  "f12","f13","f14","f15","f16","f17",	\
+				  "f18","f19","f20","f21","f22","f23",	\
+				  "f24","f25","f26","f27","f28","f29",	\
+				  "f30","f31","memory");			\
+		}							\
+	} while (0)
+
+#define evl_check_fpregs(__features, __val, __bad)			\
+	({								\
+		unsigned int __result = (__val);			\
+		if (__features & evl_riscv_fp) {			\
+			unsigned long __e[32];				\
+			unsigned int __i;				\
+			__asm__ __volatile__(				\
+				"fmv.x.d %0, f0\n"			\
+				: "=r"(__e[0]));			\
+			for (__i = 0; __i < 32; __i++) {		\
+				if (__e[0] != (unsigned long)(__val)) {	\
+					__result = __e[0];		\
+					(__bad) = __i;			\
+					break;				\
+				}					\
+			}						\
+		}							\
+		__result;						\
+	})
+
+#endif /* !_EVL_RISCV_ASM_UAPI_FPTEST_H */
