+
+#ifdef CONFIG_IRQ_PIPELINE
+/*
+ * irq_send_oob_ipi - send an out-of-band IPI to a set of CPUs.
+ *
+ * On RISC-V, OOB IPIs use slots OOB_IPI_OFFSET..OOB_IPI_OFFSET+OOB_NR_IPI-1
+ * of the IPI mux (ipi_virq_base + offset).
+ */
+void irq_send_oob_ipi(unsigned int irq, const struct cpumask *cpumask)
+{
+	unsigned int slot = irq - ipi_virq_base;
+
+	if (WARN_ON(irq_pipeline_debug() &&
+		    (slot < OOB_IPI_OFFSET ||
+		     slot >= OOB_IPI_OFFSET + OOB_NR_IPI)))
+		return;
+
+	__ipi_send_mask(ipi_desc[slot], cpumask);
+}
+EXPORT_SYMBOL_GPL(irq_send_oob_ipi);
