+int evl_nrthreads;
+
+LIST_HEAD(evl_thread_list);
+
+static DEFINE_HARD_SPINLOCK(thread_list_lock);
+
+static DECLARE_WAIT_QUEUE_HEAD(join_all);
+
+static const struct file_operations thread_fops;
