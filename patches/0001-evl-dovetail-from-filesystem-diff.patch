+	&dev_attr_cpus.attr,
+#ifdef CONFIG_EVL_SCHED_QUOTA
+	&dev_attr_quota.attr,
+#endif
+#ifdef CONFIG_EVL_SCHED_TP
+	&dev_attr_tp.attr,
+#endif
+	NULL,
+};
+ATTRIBUTE_GROUPS(control);
+
+struct evl_factory evl_control_factory = {
